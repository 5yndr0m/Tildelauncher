<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges
        </item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:colorEdgeEffect">@android:color/transparent</item>

        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
        <item name="android:colorBackgroundCacheHint">@null</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!--        <item name="android:enforceStatusBarContrast">false</item>-->
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <!--        <item name="android:windowTranslucentStatus">false</item>-->
        <!--        <item name="android:windowTranslucentNavigation">true</item>-->

        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@android:color/darker_gray</item>
        <item name="colorAccent">@color/black</item>

        <item name="primaryColor">@color/black</item>
        <item name="primaryInverseColor">@color/blackInverse</item>
        <item name="primaryTextShadowColor">@color/blackInverseTrans50</item>
        <item name="primaryColorTrans50">@color/blackTrans50</item>
        <item name="primaryColorTrans80">@color/blackTrans80</item>
        <item name="primaryColorInverseTrans50">@color/blackInverseTrans50</item>
        <item name="primaryColorInverseTrans80">@color/blackInverseTrans80</item>
        <item name="primaryColorInverseTrans90">@color/blackInverseTrans90</item>
        <item name="primaryShadeColor">@color/blackInverseTrans10</item>
        <item name="primaryShadeDarkColor">@color/blackInverseTrans25</item>
        <item name="dialogShadeColor">@color/blackInverseTrans50</item>
        <item name="launcherTextColor">?attr/primaryColor</item>
        <item name="launcherFont">sans-serif-light</item>

    </style>

    <style name="WindowAnimationTransition">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="FontSystem">
        <item name="launcherFont">sans-serif-light</item>
    </style>

    <style name="FontSans">
        <item name="launcherFont">sans-serif</item>
    </style>

    <style name="FontSerif">
        <item name="launcherFont">serif</item>
    </style>

    <style name="FontMono">
        <item name="launcherFont">monospace</item>
    </style>

    <style name="FontGeist">
        <item name="launcherFont">@font/geist</item>
    </style>

    <style name="FontGeistMono">
        <item name="launcherFont">@font/geist_mono</item>
    </style>

    <style name="FontGaramond">
        <item name="launcherFont">@font/eb_garamond</item>
    </style>

    <style name="FontRoboto">
        <item name="launcherFont">@font/roboto</item>
    </style>

    <!-- Color Presets -->
    <style name="ColorWhite">
        <item name="launcherTextColor">@color/preset_white</item>
    </style>

    <style name="ColorBlack">
        <item name="launcherTextColor">@color/preset_black</item>
    </style>

    <style name="ColorGray">
        <item name="launcherTextColor">@color/preset_gray</item>
    </style>

    <style name="ColorRed">
        <item name="launcherTextColor">@color/preset_red</item>
    </style>

    <style name="ColorBlue">
        <item name="launcherTextColor">@color/preset_blue</item>
    </style>

    <style name="ColorGreen">
        <item name="launcherTextColor">@color/preset_green</item>
    </style>

    <style name="ColorYellow">
        <item name="launcherTextColor">@color/preset_yellow</item>
    </style>

    <style name="ColorOrange">
        <item name="launcherTextColor">@color/preset_orange</item>
    </style>

    <style name="ColorPurple">
        <item name="launcherTextColor">@color/preset_purple</item>
    </style>

    <style name="ColorPink">
        <item name="launcherTextColor">@color/preset_pink</item>
    </style>

    <style name="ColorTeal">
        <item name="launcherTextColor">@color/preset_teal</item>
    </style>

    <style name="AppSearchText" parent="Widget.AppCompat.SearchView">
        <item name="android:maxLength">200</item>
        <item name="android:textSize">@dimen/text_large</item>
        <item name="android:textColor">?attr/launcherTextColor</item>
        <item name="android:editTextColor">?attr/launcherTextColor</item>
        <item name="android:textColorHint">?attr/launcherTextColor</item>
        <item name="fontFamily">?attr/launcherFont</item>
        <item name="android:inputType">textCapSentences|textNoSuggestions</item>
        <item name="android:cursorVisible">false</item>
    </style>

    <style name="TextDefault" parent="@android:style/TextAppearance.Large">
        <item name="fontFamily">?attr/launcherFont</item>
        <item name="android:fontFamily">?attr/launcherFont</item>
        <item name="android:textColor">@drawable/text_colors_default</item>
        <item name="android:textColorHint">?attr/primaryColorTrans80</item>
        <item name="android:shadowColor">?attr/primaryTextShadowColor</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="TextLarge" parent="TextDefault">
        <item name="android:textSize">@dimen/text_large</item>
    </style>

    <style name="TextMedium" parent="TextDefault">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextSmall" parent="TextDefault">
        <item name="android:textSize">@dimen/text_small</item>
    </style>

    <style name="TextSmallBold" parent="TextSmall">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSmallLight" parent="TextSmall">
        <item name="android:textColor">@drawable/text_colors_light</item>
    </style>

</resources>